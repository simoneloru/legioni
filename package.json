{
  "name": "legioni",
  "version": "0.5.2",
  "description": "A portable, maturing team of AI coding agents. My name is Legion, for we are many.",
  "repository": {
    "type": "git",
    "url": "https://github.com/simoneloru/legioni"
  },
  "license": "MIT",
  "keywords": [
    "ai",
    "coding-agent",
    "opencode",
    "multi-agent",
    "llm",
    "cli",
    "team",
    "orchestrator",
    "code-generation",
    "autonomous"
  ],
  "bin": {
    "legioni": "./bin/legioni.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck",
    "test": "vitest run"
  },
  "files": [
    "dist/",
    "bin/",
    "defaults/",
    "!dist/__tests__",
    "!dist/**/*.test.*"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
